{
  "name": "@liteforge/devtools",
  "version": "0.1.0",
  "description": "DevTools panel for debugging signals, stores, router, and components with time-travel debugging.",
  "author": "SchildW3rk <contact@schildw3rk.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schildw3rk/liteforge",
    "directory": "packages/devtools"
  },
  "homepage": "https://github.com/schildw3rk/liteforge#readme",
  "bugs": {
    "url": "https://github.com/schildw3rk/liteforge/issues"
  },
  "keywords": [
    "liteforge",
    "devtools",
    "debugging",
    "signals",
    "stores",
    "time-travel",
    "developer-tools"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@liteforge/core": ">=0.1.0",
    "@liteforge/runtime": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@liteforge/runtime": {
      "optional": true
    }
  },
  "devDependencies": {
    "@liteforge/core": "workspace:*",
    "@liteforge/runtime": "workspace:*",
    "@liteforge/store": "workspace:*"
  }
}
