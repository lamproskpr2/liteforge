{
  "name": "@liteforge/admin",
  "version": "0.2.0",
  "description": "Signals-based admin panel for LiteForge",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./css/styles.css"
  },
  "files": [
    "dist",
    "css",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "css/*.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "@liteforge/core": "*",
    "@liteforge/runtime": "*",
    "@liteforge/client": "*",
    "@liteforge/router": "*",
    "@liteforge/form": "*",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@liteforge/client": {
      "optional": true
    },
    "@liteforge/router": {
      "optional": true
    },
    "@liteforge/form": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@liteforge/core": "workspace:*",
    "@liteforge/runtime": "workspace:*",
    "@liteforge/client": "workspace:*",
    "@liteforge/router": "workspace:*",
    "@liteforge/form": "workspace:*",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "license": "MIT"
}
