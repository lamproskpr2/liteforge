{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "paths": {
      "@liteforge/core": ["../../packages/core/src/index.ts"],
      "@liteforge/core/*": ["../../packages/core/src/*"],
      "@liteforge/runtime": ["../../packages/runtime/src/index.ts"],
      "@liteforge/runtime/*": ["../../packages/runtime/src/*"],
      "@liteforge/router": ["../../packages/router/src/index.ts"],
      "@liteforge/router/*": ["../../packages/router/src/*"],
      "@liteforge/query": ["../../packages/query/src/index.ts"],
      "@liteforge/query/*": ["../../packages/query/src/*"],
      "@liteforge/form": ["../../packages/form/src/index.ts"],
      "@liteforge/form/*": ["../../packages/form/src/*"],
      "@liteforge/table": ["../../packages/table/src/index.ts"],
      "@liteforge/table/*": ["../../packages/table/src/*"],
      "@liteforge/client": ["../../packages/client/src/index.ts"],
      "@liteforge/client/*": ["../../packages/client/src/*"],
      "@liteforge/calendar": ["../../packages/calendar/src/index.ts"],
      "@liteforge/calendar/*": ["../../packages/calendar/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
